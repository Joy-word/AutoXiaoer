<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingStart="16dp"
        android:paddingTop="8dp"
        android:paddingEnd="16dp"
        android:paddingBottom="8dp">

        <TextView
            android:id="@+id/exportDescText"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/settings_export_dialog_desc"
            android:textColor="@color/text_secondary"
            android:textSize="14sp" />

        <CheckBox
            android:id="@+id/checkExportSelectAll"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:text="@string/settings_export_select_all"
            android:textSize="16sp" />

        <CheckBox
            android:id="@+id/checkExportPersona"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:checked="true"
            android:text="@string/settings_export_section_persona"
            android:textSize="16sp" />

        <CheckBox
            android:id="@+id/checkExportBehaviorRules"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:checked="true"
            android:text="@string/settings_export_section_behavior_rules"
            android:textSize="16sp" />

        <CheckBox
            android:id="@+id/checkExportRelationships"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:checked="true"
            android:text="@string/settings_export_section_relationships"
            android:textSize="16sp" />

        <CheckBox
            android:id="@+id/checkExportSystemPrompts"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/settings_export_section_system_prompts"
            android:textSize="16sp" />

        <CheckBox
            android:id="@+id/checkExportTaskHistory"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/settings_export_section_task_history"
            android:textSize="16sp" />

        <CheckBox
            android:id="@+id/checkExportScheduledTasks"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/settings_export_section_scheduled_tasks"
            android:textSize="16sp" />

        <CheckBox
            android:id="@+id/checkExportTaskTemplates"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/settings_export_section_task_templates"
            android:textSize="16sp" />

    </LinearLayout>
</ScrollView>

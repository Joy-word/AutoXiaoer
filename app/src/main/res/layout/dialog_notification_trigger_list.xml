<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:minHeight="200dp"
    android:maxHeight="500dp">

    <!-- Permission Warning Banner (shown when permission not granted) -->
    <LinearLayout
        android:id="@+id/layoutPermissionWarning"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingHorizontal="16dp"
        android:paddingTop="12dp"
        android:paddingBottom="8dp"
        android:visibility="gone">

        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:cardBackgroundColor="#1FFFB300"
            app:cardCornerRadius="10dp"
            app:cardElevation="0dp"
            app:strokeColor="#33FFB300"
            app:strokeWidth="1dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:padding="12dp">

                <ImageView
                    android:layout_width="18dp"
                    android:layout_height="18dp"
                    android:src="@drawable/ic_warning"
                    app:tint="#FFB300"
                    android:layout_marginEnd="8dp" />

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="@string/notification_trigger_permission_warning"
                    android:textColor="#FFB300"
                    android:textSize="12sp" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnGrantPermission"
                    style="@style/Widget.App.Button.Text"
                    android:layout_width="wrap_content"
                    android:layout_height="32dp"
                    android:text="@string/notification_trigger_grant_permission"
                    android:textSize="12sp"
                    android:textColor="#FFB300" />

            </LinearLayout>

        </com.google.android.material.card.MaterialCardView>

    </LinearLayout>

    <!-- Rule List -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rvNotificationTriggers"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:padding="16dp"
        android:clipToPadding="false" />

    <!-- Empty State -->
    <LinearLayout
        android:id="@+id/layoutEmpty"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:orientation="vertical"
        android:gravity="center"
        android:padding="32dp"
        android:visibility="gone">

        <ImageView
            android:layout_width="64dp"
            android:layout_height="64dp"
            android:src="@drawable/ic_notifications"
            app:tint="@color/icon_secondary"
            android:alpha="0.5"
            android:layout_marginBottom="16dp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/notification_trigger_empty"
            android:textColor="@color/text_secondary"
            android:textSize="15sp" />

    </LinearLayout>

    <!-- Add Rule Button -->
    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnAddRule"
        style="@style/Widget.Material3.Button.TonalButton"
        android:layout_width="match_parent"
        android:layout_height="48dp"
        android:layout_margin="16dp"
        android:text="@string/notification_trigger_add"
        app:backgroundTint="@color/surface_variant"
        android:textColor="@color/primary"
        app:cornerRadius="12dp"
        app:icon="@drawable/ic_plus"
        app:iconGravity="textStart"
        app:iconPadding="8dp"
        app:iconTint="@color/primary" />

</LinearLayout>

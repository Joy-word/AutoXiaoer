<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background"
    tools:context=".settings.SettingsFragment">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical">

        <!-- Simple Toolbar -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:paddingHorizontal="4dp">

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="16dp"
                android:layout_weight="1"
                android:fontFamily="sans-serif-medium"
                android:text="@string/settings_title"
                android:textColor="@color/text_primary"
                android:textSize="20sp" />

        </LinearLayout>

        <ScrollView
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:clipToPadding="false"
            android:fillViewport="true">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:paddingHorizontal="16dp"
                android:paddingBottom="32dp">

                <!-- Phone-agent Settings Card -->
                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/phoneAgentSettingsCard"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="12dp"
                    app:cardBackgroundColor="@color/card_background"
                    app:cardCornerRadius="16dp"
                    app:cardElevation="0dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="16dp">

                        <TextView
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginBottom="4dp"
                            android:text="@string/settings_phone_agent_title"
                            android:textAppearance="?attr/textAppearanceTitleMedium"
                            android:textColor="@color/text_primary" />

                        <TextView
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginBottom="12dp"
                            android:text="@string/settings_phone_agent_description"
                            android:textAppearance="?attr/textAppearanceBodySmall"
                            android:textColor="@color/text_secondary" />

                        <Button
                            android:id="@+id/btnPhoneAgentSettings"
                            style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                            android:layout_width="wrap_content"
                            android:layout_height="48dp"
                            android:text="@string/settings_phone_agent_configure" />

                    </LinearLayout>

                </com.google.android.material.card.MaterialCardView>

                <!-- LLM-agent (Brain) Settings Card -->
                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/llmAgentSettingsCard"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="12dp"
                    app:cardBackgroundColor="@color/card_background"
                    app:cardCornerRadius="16dp"
                    app:cardElevation="0dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="16dp">

                        <TextView
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginBottom="4dp"
                            android:text="LLM-agent（大脑）"
                            android:textAppearance="?attr/textAppearanceTitleMedium"
                            android:textColor="@color/text_primary" />

                        <TextView
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginBottom="12dp"
                            android:text="配置负责任务规划和文本生成的大语言模型，可使用与 phone-agent 不同的模型和 API。"
                            android:textAppearance="?attr/textAppearanceBodySmall"
                            android:textColor="@color/text_secondary" />

                        <Button
                            android:id="@+id/btnLLMAgentSettings"
                            style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                            android:layout_width="wrap_content"
                            android:layout_height="48dp"
                            android:text="配置 LLM-agent" />

                    </LinearLayout>

                </com.google.android.material.card.MaterialCardView>

                <!-- ClawBot Connection Card -->
                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/clawBotSettingsCard"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="12dp"
                    app:cardBackgroundColor="@color/card_background"
                    app:cardCornerRadius="16dp"
                    app:cardElevation="0dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="16dp">

                        <TextView
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginBottom="4dp"
                            android:text="ClawBot 连接"
                            android:textAppearance="?attr/textAppearanceTitleMedium"
                            android:textColor="@color/text_primary" />

                        <TextView
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginBottom="12dp"
                            android:text="连接 ClawBot 后，可通过微信接收指令并回复消息。"
                            android:textAppearance="?attr/textAppearanceBodySmall"
                            android:textColor="@color/text_secondary" />

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:gravity="center_vertical"
                            android:orientation="horizontal">

                            <TextView
                                android:id="@+id/clawBotStatusText"
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:text="未连接"
                                android:textAppearance="?attr/textAppearanceBodySmall"
                                android:textColor="@color/text_secondary" />

                            <Button
                                android:id="@+id/btnClawBotAction"
                                style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                                android:layout_width="wrap_content"
                                android:layout_height="48dp"
                                android:text="连接" />

                        </LinearLayout>

                    </LinearLayout>

                </com.google.android.material.card.MaterialCardView>

                <!-- Permissions Center Card (Collapsible) -->
                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/permissionsCenterCard"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="12dp"
                    app:cardBackgroundColor="@color/card_background"
                    app:cardCornerRadius="16dp"
                    app:cardElevation="0dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="16dp">

                        <!-- Header (clickable to expand/collapse) -->
                        <LinearLayout
                            android:id="@+id/permissionsHeader"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:gravity="center_vertical"
                            android:orientation="horizontal">

                            <ImageView
                                android:layout_width="40dp"
                                android:layout_height="40dp"
                                android:contentDescription="Permissions"
                                android:src="@drawable/ic_check_circle"
                                app:tint="@color/icon_primary" />

                            <LinearLayout
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_marginStart="16dp"
                                android:layout_weight="1"
                                android:orientation="vertical">

                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="@string/permissions_center_title"
                                    android:textColor="@color/text_primary"
                                    android:textSize="16sp" />

                                <TextView
                                    android:id="@+id/permissionsSummary"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:layout_marginTop="2dp"
                                    android:textColor="@color/text_secondary"
                                    android:textSize="14sp"
                                    tools:text="3/4 已授权" />

                            </LinearLayout>

                            <ImageButton
                                android:id="@+id/btnExpandCollapse"
                                android:layout_width="40dp"
                                android:layout_height="40dp"
                                android:background="?attr/selectableItemBackgroundBorderless"
                                android:contentDescription="Expand/Collapse"
                                android:src="@drawable/ic_expand_more"
                                app:tint="@color/icon_secondary" />

                        </LinearLayout>

                        <!-- Permissions Content (collapsible) -->
                        <LinearLayout
                            android:id="@+id/permissionsContent"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="16dp"
                            android:orientation="vertical"
                            android:visibility="gone"
                            tools:visibility="visible">

                            <!-- Shizuku Permission -->
                            <include
                                android:id="@+id/permissionShizuku"
                                layout="@layout/item_permission_status" />

                            <!-- Overlay Permission -->
                            <include
                                android:id="@+id/permissionOverlay"
                                layout="@layout/item_permission_status" />

                            <!-- Keyboard Permission -->
                            <include
                                android:id="@+id/permissionKeyboard"
                                layout="@layout/item_permission_status" />

                            <!-- Battery Permission -->
                            <include
                                android:id="@+id/permissionBattery"
                                layout="@layout/item_permission_status" />

                        </LinearLayout>

                    </LinearLayout>

                </com.google.android.material.card.MaterialCardView>

                <!-- Debug Logs Card -->
                <com.google.android.material.card.MaterialCardView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="12dp"
                    app:cardBackgroundColor="@color/card_background"
                    app:cardCornerRadius="16dp"
                    app:cardElevation="0dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="16dp">

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:gravity="center_vertical"
                            android:orientation="horizontal">

                            <ImageView
                                android:layout_width="40dp"
                                android:layout_height="40dp"
                                android:contentDescription="Debug"
                                android:src="@drawable/ic_bug_report"
                                app:tint="@color/icon_primary" />

                            <LinearLayout
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_marginStart="16dp"
                                android:layout_weight="1"
                                android:orientation="vertical">

                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="@string/settings_debug_logs"
                                    android:textColor="@color/text_primary"
                                    android:textSize="16sp" />

                                <TextView
                                    android:id="@+id/logSizeText"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:layout_marginTop="2dp"
                                    android:text="@string/settings_debug_logs_description"
                                    android:textColor="@color/text_secondary"
                                    android:textSize="14sp" />

                            </LinearLayout>

                        </LinearLayout>

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="16dp"
                            android:orientation="horizontal">

                            <com.google.android.material.button.MaterialButton
                                android:id="@+id/btnExportLogs"
                                style="@style/Widget.App.Button.Secondary"
                                android:layout_width="0dp"
                                android:layout_height="48dp"
                                android:layout_marginEnd="8dp"
                                android:layout_weight="1"
                                android:text="@string/settings_export_logs"
                                app:icon="@drawable/ic_share"
                                app:iconGravity="textStart"
                                app:iconPadding="8dp"
                                app:strokeColor="@color/primary"
                                app:strokeWidth="1dp" />

                            <com.google.android.material.button.MaterialButton
                                android:id="@+id/btnClearLogs"
                                style="@style/Widget.App.Button.Text.Secondary"
                                android:layout_width="wrap_content"
                                android:layout_height="48dp"
                                android:text="@string/settings_clear_logs" />

                        </LinearLayout>

                    </LinearLayout>

                </com.google.android.material.card.MaterialCardView>

            </LinearLayout>
        </ScrollView>

    </LinearLayout>

</androidx.coordinatorlayout.widget.CoordinatorLayout>
